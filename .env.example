# Exchange and market
EXCHANGE=binance
SYMBOL=BTC/USDT

# Market maker loop
POLL_INTERVAL_SEC=2
QUOTE_SPREAD_BPS=10
QUOTE_SIZE=0.001
MAX_POSITION_BASE=0.01

# Storage
DB_URL=sqlite:///./data/mm_lab.db

# Fees (basis points)
MAKER_FEE_BPS=10
TAKER_FEE_BPS=10

# Strategy: pure_mm | inventory_skew | volatility_spread
STRATEGY=pure_mm
