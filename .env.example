# Exchange and market
EXCHANGE=binance
SYMBOL=BTC/USDT

# Market maker loop
POLL_INTERVAL_SEC=2
QUOTE_SPREAD_BPS=10
QUOTE_SIZE=0.001
MAX_POSITION_BASE=0.01
LOOP_ENABLED=true
METRICS_ENABLED=true

# Storage (use DATABASE_URL for Postgres in Docker)
DB_URL=sqlite:///./data/mm_lab.db
# DATABASE_URL=postgresql://mmlab:mmlab@localhost:5432/mmlab

# Fees (basis points)
MAKER_FEE_BPS=10
TAKER_FEE_BPS=10

# Fill simulation: full_cross_fill | partial_fill
FILL_MODE=full_cross_fill

# Strategy: pure_mm | inventory_skew | volatility_spread
STRATEGY=pure_mm

# Paper trading capital
INITIAL_QUOTE_BALANCE=10000
MAX_POSITION_NOTIONAL=1000
REPORT_INTERVAL_TICKS=5

# DEX comparison (V2)
DEX_ENABLED=true
ETH_RPC_URL=https://ethereum.publicnode.com
DEX_POOL_ADDRESS=0xB4e16d0168e52d35CaC2c6185b44281Ec1C50942
CEX_COMPARE_SYMBOL=ETH/USDT
AMM_FEE_BPS=30
ARBITRAGE_TRIAL_TRADE_SIZE=0.1
ARBITRAGE_MIN_EDGE_BPS=5
GAS_LIMIT_UNITS=200000
GAS_PRICE_GWEI=30
INVENTORY_TARGET_BASE=0
INVENTORY_SKEW_BPS=20

# Volatility spread strategy
VOLATILITY_WINDOW=20
VOLATILITY_SPREAD_MULTIPLIER=1.0
